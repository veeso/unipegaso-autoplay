{
  "name": "unipegaso-autoplay",
  "version": "0.1.4",
  "description": "Firefox extension that automatically skips to the next lesson on Unipegaso video lesson pages when the current one is completed.",
  "private": true,
  "author": "Christian Visintin <christian.visintin@veeso.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/veeso/unipegaso-autoplay.git"
  },
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "package": "npm run build && web-ext build --source-dir=dist --artifacts-dir=web-ext-artifacts --overwrite-dest && npm run package:source",
    "package:source": "node scripts/source-zip.mjs",
    "start:firefox": "npm run build && web-ext run --source-dir=dist",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,json,md,html,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "web-ext": "^10.1.0"
  }
}
